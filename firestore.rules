rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    // Check if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the authenticated user matches the provided userId
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if the user is an admin by reading their profile role
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // --- COLLECTION RULES ---

    // 1. User profiles - Publicly readable for role checks and identity, but only owner/admin can write
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();

      // Subcollection for user-specific book data
      match /books/{bookId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 2. Reviews - Publicly readable, owner/admin writable
    match /reviews/{reviewId} {
      allow read: if true; // Publicly readable
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();

      // Data validation for reviews
      allow create, update: if 
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5 &&
        request.resource.data.comment is string &&
        request.resource.data.comment.size() > 0;
    }

    // 3. Events - Publicly readable, admin-only writable
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Event Cache - Publicly readable (internal caching), admin-only writable
    match /event_cache/{cacheId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Legacy/Alternative user books collection
    match /user_books/{docId} {
      // Document ID is expected to be {userId}_{bookId}
      allow read, write: if isSignedIn() && (
        docId.startsWith(request.auth.uid + "_") || isAdmin()
      );
    }

    // Default: Block all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
